# EJEMPLO de variables para desarrollo con Docker
# Copiar este archivo a .env.dev y completar con valores reales.

# Base de datos
DB_URL=mysql+pymysql://usuario:contraseña@db:3306/nombre_db
DB_ROOT_PASSWORD=contraseña_root
DB_NAME=nombre_db_dev
DB_USER=usuario_db
DB_PASSWORD=contraseña_segura

# Configuración de aplicación
ENV=development
DEV_API_URL=http://localhost:8000/api/v1

# Inicialización
INIT_BASE_STRUCTURE=true
INIT_DEPARTMENT_DATA=true
INTERACTIVE_ADMIN=false

# Configuración de email
EMAIL_ENABLED=true
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=465
SMTP_TLS=true
SMTP_USER=usuario@ejemplo.com
SMTP_PASSWORD=contraseña_email
EMAILS_FROM_EMAIL=noreply@ejemplo.com
EMAILS_FROM_NAME=Nombre Sistema (Dev)

# NOTA: Este archivo se usa cuando se ejecuta con Docker Compose en modo desarrollo
# Comando: docker-compose up
