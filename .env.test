# ===============================================
# .env.test - CONFIGURACIÓN DE TESTING
# ===============================================

# Perfil de Docker Compose
COMPOSE_PROFILES=test

# Base de datos (temporal para testing)
DB_ROOT_PASSWORD=testpassword
DB_NAME=medialab_test_db
DB_USER=test_user
DB_PASSWORD=testpassword
DB_PORT=3307

# Backend
BACKEND_PORT=8001
ENVIRONMENT=testing

# Frontend
VITE_API_URL=http://localhost:8001/api/v1
VITE_FRONTEND_URL=http://localhost:5174

# Configuración mínima para testing
SECRET_KEY=test-secret-key-not-secure
TOKEN_BLACKLIST_ENABLED=false
RATE_LIMIT_ENABLED=false
EMAIL_ENABLED=false