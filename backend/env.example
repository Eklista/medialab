# Ejemplo de archivo .env para el backend de MediaLab
# Reemplaza los valores con tus propias credenciales

# Configuración de la base de datos
DATABASE_URL=mysql+pymysql://usuario:contraseña@localhost/nombre_db
SECRET_KEY=clave_secreta_de_ejemplo

# Configuración SMTP
EMAIL_ENABLED=True
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=tu_usuario@ejemplo.com
SMTP_PASSWORD=tu_contraseña
EMAILS_FROM_EMAIL=correo@ejemplo.com
EMAILS_FROM_NAME=Nombre del Remitente

# URLs del frontend
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://tu-dominio.com

# Entorno
ENVIRONMENT=development  # development para desarrollo, production para producción